# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Cloudflare Worker API URL
# For local dev keep this as-is. Change to your deployed Worker URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8787

# ─── Calendarific ─────────────────────────────────────────────────────────────
# Provides real festival dates via API.
# Free key available at: https://calendarific.com/signup
NEXT_PUBLIC_CALENDARIFIC_KEY=your_calendarific_key_here

# ─── Apify ────────────────────────────────────────────────────────────────────
# Powers the Benchmarking feature — auto-scrapes likes/views/comments from
# Instagram, Twitter/X, and Facebook post URLs.
# YouTube does NOT need this key (it uses direct scraping).
#
# Steps to get your token:
#   1. Sign up at https://apify.com (free plan available)
#   2. Go to Settings → Integrations
#   3. Copy your Personal API token and paste it below
APIFY_TOKEN=your_apify_token_here
